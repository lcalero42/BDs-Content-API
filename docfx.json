{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "DbsContentApi.csproj"
          ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "netstandard2.1",
        "Configuration": "Release"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**",
          "bin/**",
          "decomp/**",
          "build-metadata/**",
          "steam-build/**",
          "filterConfig.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "DbsContentApi",
      "_appTitle": "DbsContentApi Documentation",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
