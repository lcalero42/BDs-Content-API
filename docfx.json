{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "DbsContentApi.csproj"
          ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "netstandard2.1",
        "Configuration": "Release"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**",
          "bin/**",
          "decomp/**",
          "build-metadata/**",
          "steam-build/**",
          "filterConfig.yml",
          "apidoc/**"
        ]
      },
      {
        "files": [
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "overwrite": "apidoc/overwrites/**/*.md",
    "output": "_site",
    "template": [
      "modern",
      "templates/dbscontentapi"
    ],
    "globalMetadata": {
      "_appName": "DbsContentApi",
      "_appTitle": "DbsContentApi — Content Warning Mod SDK",
      "_appFooter": "DbsContentApi · Content Warning modding SDK",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/lcalero42/BDs-Content-API",
        "branch": "main"
      },
      "pdf": false
    },
    "fileMetadata": {
      "priority": {
        "docs/index.md": 100,
        "docs/quick-start.md": 90,
        "docs/introduction.md": 80,
        "docs/getting-started.md": 70
      }
    }
  }
}
